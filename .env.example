# --- Orchestrator ---
# Port the WebUI/API is exposed on the host
ORCHESTRATOR_PORT=8787

# UID/GID for the orchestrator and spawned worker containers. Match your host
# user so bind-mounted files (./data/*) stay owned by you.
PUID=1000
PGID=1000

# GID of the docker group on the host (owner of /var/run/docker.sock).
# Find with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=989

# Used to encrypt secrets (GitHub PAT, Telegram token) in the SQLite DB.
# Generate with: openssl rand -base64 32
SECRET_KEY=change-me-to-a-random-32-byte-base64

# Basic auth for the WebUI (comma-separated user:password pairs, bcrypt optional later)
# Leave empty for no auth (only safe if bound to localhost)
UI_BASIC_AUTH=admin:changeme

# --- Worker runtime ---
# Image tag built from ./worker-image
WORKER_IMAGE=runhelm-worker:latest

# Docker network workers are attached to (created by compose)
WORKER_NETWORK=claude-workers_workers

# Host path where project repos live (bind-mounted into workers)
# Absolute path required so workers can see the same files
REPOS_HOST_PATH=/opt/docker/stacks/claude-workers/data/repos

# Host path where the shared Claude auth volume is mounted (ro into workers)
CLAUDE_AUTH_HOST_PATH=/opt/docker/stacks/claude-workers/data/claude-auth

# --- Internal ---
# URL the worker uses to reach the orchestrator (inside the docker network)
ORCHESTRATOR_INTERNAL_URL=http://orchestrator:8787

# --- Self-deploy ---
# Absolute host path of this stack. The deployer sidecar bind-mounts this to run
# `docker compose build/up` against the compose file on the host.
STACK_HOST_PATH=/opt/docker/stacks/claude-workers

# Image name the orchestrator container runs as. Backups are tagged
# <orchestrator_image>:backup-<timestamp>; :previous is the last known-good.
ORCHESTRATOR_IMAGE=runhelm:latest
DEPLOYER_IMAGE=runhelm-deployer:latest
